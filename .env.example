# MongoDB
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=change_me_to_a_strong_password
MONGODB_DATABASE=cpc

# Redis
REDIS_PASSWORD=change_me_to_a_strong_password

# JWT (generate a strong random string, e.g. 64 bytes base64 encoded)
JWT_SECRET=change_me_to_a_strong_random_secret

# Google OAuth (get from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URL=https://your-domain.com/api/v1/auth/oauth/google/callback

# SMTP (for Gmail use an App Password, not your login password)
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your_smtp_app_password

# Admin account
ADMIN_EMAIL=root@example.com
ADMIN_INITIAL_PASSWORD=change_me_to_a_strong_random_password

# CSRF (32+ byte random key, base64 encoded)
CSRF_AUTH_KEY=change_me_to_a_32_byte_random_key

# Security / CORS
SECURE_COOKIE=false
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
